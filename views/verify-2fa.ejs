<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify 2FA</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <h1>2FA Verification</h1>
      <p>Step 2: Enter the 6-digit code from your authenticator app.</p>

      <% if (error) { %>
      <p class="error"><%= error %></p>
      <% } %>

      <form action="/verify-2fa" method="post" class="card">
        <input type="hidden" name="email" value="<%= email %>" />

        <label>Email</label>
        <input type="email" value="<%= email %>" disabled />

        <label>2FA Code</label>
        <input type="text" name="code" minlength="6" maxlength="6" required />

        <button type="submit">Verify and Generate Token</button>
      </form>
    </main>
  </body>
</html>
