<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Token Generated</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <h1>Authentication Success</h1>
      <p>Password + 2FA verified. JWT token generated:</p>

      <textarea readonly rows="8"><%= token %></textarea>

      <form action="/set-token" method="post" class="inline-form">
        <input type="hidden" name="token" value="<%= token %>" />
        <button type="submit">Go to Dashboard using token</button>
      </form>
    </main>
  </body>
</html>
